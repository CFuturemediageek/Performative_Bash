#LVM SCENARIO 3 (Full workflow + filesystem grow)
#You have a new disk available at /dev/sdd.
#Your system already has:
#• A volume group called vgdata
#• An existing LV: /dev/vgdata/lvbackup
#• Your task is to create a NEW logical volume, format it, mount it, AND then extend it.


#LVM Scenario 3. 

pvcreate /dev/sdd 

vgextend vgdata /dev/sdd 

lvcreate -L 3G -n lvarchive vgdata 
mkfs.xfs /dev/vgdata/lvarchive 

mkdir -p /archive 

echo "/dev/vgdata/lvarchive /archive xfs defaults 0 0" | sudo tee -a /etc/fstab 

mount -a 

lvextend -r -L +2G /dev/vgdata/lvarchive 









