sudo tee /home/backup_home.sh > /dev/null << 'EOF'

#!/usr/bin/env bash
LOG="/var/log/homebackup.log"
BACKUP="/var/backups/home.tar.gz"


echo "Backup started: $(date)" >> "$LOG"
if tar czf "$BACKUP" /home >> "$LOG" 2>&1; then
 echo "Backup completed successfully: $(date)" >> "$LOG"
 exit 0
else
 echo "Backup FAILED: $(date)" >> "$LOG"
 exit 1
fi
EOF


